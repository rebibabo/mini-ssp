{
  "title": "竞价大盘",
  "uid": "mini-ssp-overview",
  "tags": ["mini-ssp"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "timezone": "browser",
  "graphTooltip": 1,
  "annotations": {"list": []},
  "templating": {"list": []},
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "竞价 QPS（次/秒）",
      "description": "fill/no_fill 每秒请求数",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(ssp_bid_requests_total[1m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "No Fill 率",
      "description": "没有拿到广告的请求占比（0~100%）",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(ssp_bid_requests_total{result=\"no_fill\"}[1m])) / sum(rate(ssp_bid_requests_total[1m]))",
          "legendFormat": "no_fill 率",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DSP 出价结果（次/秒）",
      "description": "各 DSP 的 win/lose/no_bid/error/rate_limited/timeout 分布",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(ssp_dsp_bid_total[1m])) by (dsp_id, result)",
          "legendFormat": "{{dsp_id}} · {{result}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DSP 调用耗时 P99（ms）",
      "description": "各 DSP HTTP 调用的 P99 延迟，超过 globalTimeoutMs(200ms) 会被截断",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(ssp_dsp_call_duration_seconds_bucket[1m])) by (le, dsp_id)) * 1000",
          "legendFormat": "{{dsp_id}} P99",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    }
  ]
}
